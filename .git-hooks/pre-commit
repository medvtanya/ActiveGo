#!/bin/sh

###########################################
# Pre-commit hook для проверки кода
# Выполняет линтинг и сборку проекта
###########################################

echo "🚀 Запуск pre-commit проверок..."

# Сохраняем текущую директорию для возврата
CURRENT_DIR=$(pwd)

# Переходим в директорию client
echo "📂 Переход в директорию client..."
cd client || {
    echo "❌ Ошибка: Не удалось перейти в директорию client"
    exit 1
}

# Проверка линтинга JavaScript/TypeScript
echo "🔍 Проверка линтинга JS/TS файлов..."
npm run lint || {
    echo "❌ Ошибка линтинга JS/TS"
    cd "$CURRENT_DIR"
    exit 1
}

# Проверка и исправление стилей CSS
echo "🎨 Проверка CSS файлов..."
npx stylelint "**/*.css" --ignore-path .stylelintignore --fix || {
    echo "❌ Ошибка линтинга CSS"
    cd "$CURRENT_DIR"
    exit 1
}

# Сборка проекта
echo "🏗️ Сборка проекта..."
npm run build || {
    echo "❌ Ошибка сборки проекта"
    cd "$CURRENT_DIR"
    exit 1
}

# Возвращаемся в исходную директорию
cd "$CURRENT_DIR"

echo "✅ Все проверки успешно пройдены! Можно выполнять коммит."